<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="420.0"
            prefWidth="650.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifpb.ads.foodjava.controller.LoginController">

    <children>

        <Label layoutX="250"
               layoutY="25"
               text="FoodJava"
               style="-fx-font-size:26px;-fx-font-weight:bold;"/>

        <Label layoutX="120"
               layoutY="120"
               text="E-mail"/>

        <TextField fx:id="txtEmail"
                   layoutX="200"
                   layoutY="115"
                   prefWidth="250"
                   promptText="Digite seu e-mail"/>

        <Label layoutX="120"
               layoutY="180"
               text="Senha"/>

        <PasswordField fx:id="txtSenha"
                       layoutX="200"
                       layoutY="175"
                       prefWidth="250"
                       promptText="Digite sua senha"/>

        <Button fx:id="btnEntrar"
                layoutX="120"
                layoutY="270"
                prefWidth="120"
                text="Entrar"
                onAction="#entrar"/>

        <Button fx:id="btnCadastrarCliente"
                layoutX="260"
                layoutY="270"
                prefWidth="160"
                text="Cadastrar Cliente"
                onAction="#abrirCadastroCliente"/>

    </children>

</AnchorPane>