<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="420.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifpb.ads.foodjava.controller.LoginController">

    <children>

        <Label layoutX="267.0" layoutY="52.0" style="-fx-font-size:26px;-fx-font-weight:bold;" text="FoodJava" />

        <Label layoutX="156.0" layoutY="153.0" text="E-mail" />

        <TextField fx:id="txtEmail" layoutX="200.0" layoutY="149.0" prefWidth="250" promptText="Digite seu e-mail" />

        <Label layoutX="156.0" layoutY="196.0" text="Senha" />

        <PasswordField fx:id="txtSenha" layoutX="200.0" layoutY="192.0" onAction="#entrar" prefWidth="250" promptText="Digite sua senha" />

        <Button fx:id="btnEntrar" defaultButton="true" layoutX="163.0" layoutY="255.0" onAction="#entrar" prefWidth="120" text="Entrar" />

        <Button fx:id="btnCadastrarCliente" layoutX="290.0" layoutY="255.0" onAction="#abrirCadastroCliente" prefWidth="160" text="Cadastrar Cliente" />

    </children>

</AnchorPane>
