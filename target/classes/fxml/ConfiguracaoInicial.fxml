<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="550.0"
            prefWidth="750.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifpb.ads.foodjava.controller.ConfiguracaoInicialController">

    <children>

        <Label layoutX="175"
               layoutY="20"
               text="Configuração Inicial do Restaurante"
               style="-fx-font-size:22px; -fx-font-weight:bold;"/>

        <Label layoutX="120"
               layoutY="82"
               text="Nome Fantasia"/>

        <TextField fx:id="txtNomeFantasia"
                   layoutX="300"
                   layoutY="75"
                   prefWidth="320"
                   promptText="Restaurante Exemplo"/>

        <Label layoutX="120"
               layoutY="127"
               text="CNPJ"/>

        <TextField fx:id="txtCnpj"
                   layoutX="300"
                   layoutY="120"
                   prefWidth="320"
                   promptText="00.000.000/0000-00"/>

        <Label layoutX="120"
               layoutY="172"
               text="Endereço"/>

        <TextField fx:id="txtEndereco"
                   layoutX="300"
                   layoutY="165"
                   prefWidth="320"
                   promptText="Rua Exemplo, 123"/>

        <Label layoutX="120"
               layoutY="217"
               text="Telefone"/>

        <TextField fx:id="txtTelefone"
                   layoutX="300"
                   layoutY="210"
                   prefWidth="320"
                   promptText="(00) 00000-0000"/>

        <Label layoutX="120"
               layoutY="262"
               text="Categoria"/>

        <TextField fx:id="txtCategoria"
                   layoutX="300"
                   layoutY="255"
                   prefWidth="320"
                   promptText="Pizzaria, Lanches, Japonesa..."/>

        <Label layoutX="120"
               layoutY="307"
               text="Nome do Gerente"/>

        <TextField fx:id="txtNomeGerente"
                   layoutX="300"
                   layoutY="300"
                   prefWidth="320"
                   promptText="João da Silva"/>

        <Label layoutX="120"
               layoutY="352"
               text="E-mail"/>

        <TextField fx:id="txtEmail"
                   layoutX="300"
                   layoutY="345"
                   prefWidth="320"
                   promptText="gerente@email.com"/>

        <Label layoutX="120"
               layoutY="397"
               text="Senha"/>

        <PasswordField fx:id="txtSenha"
                       layoutX="300"
                       layoutY="390"
                       prefWidth="320"
                       promptText="Digite uma senha"/>

        <Button fx:id="btnSalvar"
                layoutX="270"
                layoutY="470"
                prefWidth="200"
                prefHeight="38"
                text="Salvar Configuração"
                onAction="#salvar"/>

    </children>

</AnchorPane>