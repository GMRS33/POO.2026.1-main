<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="650.0"
xmlns="http://javafx.com/javafx/21"
xmlns:fx="http://javafx.com/fxml/1"
fx:controller="br.edu.ifpb.ads.foodjava.controller.CadastroClienteController">

    <children>

        <Label layoutX="220" layoutY="20"
               text="Cadastro de Cliente"
               style="-fx-font-size:22px;-fx-font-weight:bold;"/>

        <Label layoutX="80" layoutY="80" text="Nome"/>
        <TextField fx:id="txtNome" layoutX="180" layoutY="75" prefWidth="300"/>

        <Label layoutX="80" layoutY="120" text="CPF"/>
        <TextField fx:id="txtCpf" layoutX="180" layoutY="115" prefWidth="300"/>

        <Label layoutX="80" layoutY="160" text="Telefone"/>
        <TextField fx:id="txtTelefone" layoutX="180" layoutY="155" prefWidth="300"/>

        <Label layoutX="80" layoutY="200" text="Endereço"/>
        <TextField fx:id="txtEndereco" layoutX="180" layoutY="195" prefWidth="300"/>

        <Label layoutX="80" layoutY="240" text="Email"/>
        <TextField fx:id="txtEmail" layoutX="180" layoutY="235" prefWidth="300"/>

        <Label layoutX="80" layoutY="280" text="Senha"/>
        <PasswordField fx:id="txtSenha" layoutX="180" layoutY="275" prefWidth="300"/>

        <Button text="Cadastrar"
                layoutX="180"
                layoutY="360"
                onAction="#cadastrar"/>

        <Button text="Voltar"
                layoutX="300"
                layoutY="360"
                onAction="#voltar"/>

    </children>

</AnchorPane>