<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="650" prefWidth="1000" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifpb.ads.foodjava.controller.PedidosGerenteController">

    <children>

        <Label layoutX="360" layoutY="20" style="-fx-font-size:24px;-fx-font-weight:bold;" text="Gerenciamento de Pedidos" />

        <TableView fx:id="tablePedidos" layoutX="30" layoutY="70" prefHeight="420" prefWidth="940">

            <columns>

                <TableColumn fx:id="colId" prefWidth="180" text="Código" />

                <TableColumn fx:id="colCliente" prefWidth="180" text="Cliente" />

                <TableColumn fx:id="colData" prefWidth="180" text="Data" />

                <TableColumn fx:id="colTotal" prefWidth="120" text="Total" />

                <TableColumn fx:id="colStatus" prefWidth="220" text="Status" />

            </columns>

        </TableView>

        <ComboBox fx:id="comboStatus" layoutX="110.0" layoutY="506.0" prefWidth="250" />

        <Button layoutX="427.0" layoutY="506.0" onAction="#alterarStatus" prefWidth="170" text="Alterar Status" />

        <Button layoutX="663.0" layoutY="506.0" onAction="#voltar" prefWidth="170" text="Voltar" />

    </children>

</AnchorPane>
