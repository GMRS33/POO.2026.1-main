<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0"
            prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifpb.ads.foodjava.controller.MeusPedidosController">

    <children>

        <Label layoutX="340"
               layoutY="20"
               text="Meus Pedidos"
               style="-fx-font-size:24px;-fx-font-weight:bold;"/>

        <TableView fx:id="tablePedidos"
                   layoutX="40"
                   layoutY="70"
                   prefWidth="820"
                   prefHeight="400">

            <columns>

                <TableColumn fx:id="colId"
                             text="Código"
                             prefWidth="220"/>

                <TableColumn fx:id="colData"
                             text="Data"
                             prefWidth="170"/>

                <TableColumn fx:id="colTotal"
                             text="Valor Total"
                             prefWidth="140"/>

                <TableColumn fx:id="colStatus"
                             text="Status"
                             prefWidth="220"/>

            </columns>

        </TableView>

        <Button text="Atualizar"
                layoutX="250"
                layoutY="500"
                prefWidth="150"
                onAction="#atualizar"/>

        <Button text="Voltar"
                layoutX="470"
                layoutY="500"
                prefWidth="150"
                onAction="#voltar"/>

    </children>

</AnchorPane>